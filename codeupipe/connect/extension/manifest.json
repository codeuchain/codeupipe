{
  "manifest_version": 3,
  "name": "CUP Platform Bridge",
  "version": "1.0.0",
  "description": "Browser ↔ Desktop bridge for codeupipe. Connects the CUP Platform site to native GPU compute via Native Messaging, with WASM fallback.",

  "permissions": [
    "nativeMessaging",
    "storage",
    "activeTab"
  ],

  "background": {
    "service_worker": "service-worker.js",
    "type": "module"
  },

  "content_scripts": [
    {
      "matches": [
        "https://codeuchain.github.io/*",
        "http://localhost:*/*",
        "http://127.0.0.1:*/*"
      ],
      "js": ["content-script.js"],
      "run_at": "document_start"
    }
  ],

  "externally_connectable": {
    "matches": [
      "https://codeuchain.github.io/*"
    ]
  },

  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },

  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },

  "web_accessible_resources": [
    {
      "resources": ["wasm/*"],
      "matches": ["https://codeuchain.github.io/*", "http://localhost:*/*"]
    }
  ]
}
